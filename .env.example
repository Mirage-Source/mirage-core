# MIRAGE Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Database ────────────────────────────────────────────────────────────────
DB_NAME=mirage
DB_USER=mirage
DB_PASSWORD=changeme

# DB_HOST and DB_PORT are set automatically by docker-compose.
# Only override these if running services outside of Docker.
# DB_HOST=localhost
# DB_PORT=5432

# ── Bridge / ML Worker ──────────────────────────────────────────────────────
# How often the worker polls PostgreSQL for unenriched sessions (seconds).
BRIDGE_POLL_INTERVAL_S=10

# Number of sessions processed per polling batch.
BRIDGE_BATCH_SIZE=32

# ── Neural Enrichment (optional) ────────────────────────────────────────────
# Uncomment and set these to enable 128-d behavioral embeddings.
# Place trained artifacts in ./artifacts/embedder/ first.
# Without these the worker runs in degraded mode: timing + tool signatures only.
#
# MIRAGE_MODEL_CHECKPOINT=/app/artifacts/embedder/best.pt
# MIRAGE_TOKENIZER_DIR=/app/artifacts/embedder/tokenizer
# MIRAGE_MODEL_VERSION=mirage-emb-v1
